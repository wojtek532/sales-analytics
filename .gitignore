cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data & Models (nie commituj surowych danych)
data/raw/*
models/*.pkl
models/*.joblib
!data/raw/.gitkeep
!models/.gitkeep

# Env
.env
*.env

# macOS
.DS_Store

# IDE
.idea/
.vscode/
